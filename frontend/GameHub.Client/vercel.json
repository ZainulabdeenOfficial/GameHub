{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/GameHub.Client/browser",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "angular",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "http://gamehub12.runasp.net/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
